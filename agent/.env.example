# Salesforce MCP
SF_MCP_URL=http://localhost:3000/mcp
SF_MCP_TOKEN=your_sf_access_token

# GitHub
GITHUB_TOKEN=ghp_...
REPO_OWNER=your-org
REPO_NAME=apex-da-catalog
REPO_BRANCH=main
# GitHub MCP endpoint — defaults to GitHub Copilot MCP; override for self-hosted GitHub MCP server
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/

# Path to da-manifest.json — defaults to da-manifest.json in process.cwd()
# Set this when running from a directory other than the repo root, or when
# the manifest lives at a different path.
# MANIFEST_PATH=/absolute/path/to/da-manifest.json
